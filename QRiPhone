<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="description" content="光学式CSV転送システム - 受信側。iPhoneカメラでQRコードを読み取りCSVファイルを受信。">
  <title>光学式CSV転送 - 受信側</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/pako@2.1.0/dist/pako.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary: #0d1117;
      --bg-secondary: #161b22;
      --bg-card: rgba(22, 27, 34, 0.85);
      --bg-tertiary: #21262d;
      --border: #30363d;
      --border-accent: rgba(0, 180, 216, 0.3);
      --text-primary: #e6edf3;
      --text-secondary: #8b949e;
      --text-tertiary: #6e7681;
      --accent-1: #00b4d8;
      --accent-2: #0077b6;
      --success: #3fb950;
      --warning: #d29922;
      --danger: #f85149;
      --radius: 12px;
      --radius-sm: 8px;
      --font-mono: 'JetBrains Mono', monospace;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      min-height: 100dvh;
      overflow-x: hidden;
      -webkit-text-size-adjust: 100%;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(0, 180, 216, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 100%, rgba(63, 185, 80, 0.05) 0%, transparent 50%);
      z-index: -1;
      pointer-events: none;
    }

    /* ===== Header ===== */
    .header {
      background: rgba(13, 17, 23, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-icon {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    .header h1 {
      font-size: 16px;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .header h1 span {
      color: var(--text-secondary);
      font-weight: 400;
      margin-left: 6px;
      font-size: 13px;
    }

    /* ===== Container ===== */
    .container {
      padding: 16px;
      max-width: 500px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ===== Card ===== */
    .card {
      background: var(--bg-card);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      transition: border-color 0.3s ease;
    }

    .card-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-title .icon { font-size: 14px; }

    /* ===== Camera ===== */
    .camera-container {
      position: relative;
      width: 100%;
      aspect-ratio: 4/3;
      background: #000;
      border-radius: var(--radius);
      overflow: hidden;
    }

    .camera-container video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .scan-overlay {
      position: absolute;
      inset: 8%;
      border: 2px solid rgba(0, 180, 216, 0.4);
      border-radius: var(--radius);
      pointer-events: none;
      transition: border-color 0.2s;
    }

    .scan-overlay.detected {
      border-color: var(--success);
      box-shadow: 0 0 20px rgba(63, 185, 80, 0.3);
    }

    /* Corner brackets */
    .scan-overlay::before,
    .scan-overlay::after {
      content: '';
      position: absolute;
      width: 24px;
      height: 24px;
      border-color: var(--accent-1);
      border-style: solid;
    }

    .scan-overlay::before {
      top: -1px; left: -1px;
      border-width: 3px 0 0 3px;
      border-radius: 4px 0 0 0;
    }

    .scan-overlay::after {
      top: -1px; right: -1px;
      border-width: 3px 3px 0 0;
      border-radius: 0 4px 0 0;
    }

    .corner-bl, .corner-br {
      position: absolute;
      width: 24px; height: 24px;
      border-color: var(--accent-1);
      border-style: solid;
      pointer-events: none;
    }

    .corner-bl {
      bottom: -1px; left: -1px;
      border-width: 0 0 3px 3px;
      border-radius: 0 0 0 4px;
    }

    .corner-br {
      bottom: -1px; right: -1px;
      border-width: 0 3px 3px 0;
      border-radius: 0 0 4px 0;
    }

    .scan-line {
      position: absolute;
      left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent-1), transparent);
      animation: scanLine 2.5s ease-in-out infinite;
      pointer-events: none;
    }

    @keyframes scanLine {
      0%, 100% { top: 0%; opacity: 0.6; }
      50% { top: 100%; opacity: 0.3; }
    }

    .camera-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--text-tertiary);
      gap: 8px;
    }

    .camera-placeholder .icon { font-size: 48px; opacity: 0.5; }

    /* Detection flash */
    .detection-flash {
      position: absolute;
      inset: 0;
      background: rgba(63, 185, 80, 0.15);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.1s;
      border-radius: var(--radius);
    }

    .detection-flash.active {
      opacity: 1;
    }

    /* ===== Status ===== */
    .status-section {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .status-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .status-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--text-tertiary);
      flex-shrink: 0;
    }

    .status-dot.idle { background: var(--text-tertiary); }
    .status-dot.active { background: var(--success); animation: pulse 1.5s ease infinite; }
    .status-dot.complete { background: var(--accent-1); }
    .status-dot.verified { background: var(--success); }
    .status-dot.error { background: var(--danger); }

    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(63, 185, 80, 0.4); }
      50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(63, 185, 80, 0); }
    }

    .status-label {
      font-size: 15px;
      font-weight: 500;
    }

    .status-detail {
      margin-left: auto;
      font-size: 14px;
      font-family: var(--font-mono);
      font-weight: 600;
      color: var(--accent-1);
    }

    /* Progress bar */
    .progress-bar-container {
      width: 100%;
      height: 8px;
      background: var(--bg-tertiary);
      border-radius: 4px;
      overflow: hidden;
    }

    .progress-bar-fill {
      height: 100%;
      border-radius: 4px;
      background: linear-gradient(90deg, var(--accent-1), var(--accent-2), var(--accent-1));
      background-size: 200% 100%;
      animation: shimmer 2s linear infinite;
      transition: width 0.2s ease;
      width: 0%;
    }

    .progress-bar-fill.complete {
      background: var(--success);
      animation: none;
    }

    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .progress-text {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--text-secondary);
      font-family: var(--font-mono);
      margin-top: 6px;
    }

    /* ===== Transfer Info ===== */
    .transfer-info {
      display: none;
    }

    .transfer-info.visible { display: block; }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .info-item {
      background: var(--bg-tertiary);
      border-radius: var(--radius-sm);
      padding: 10px;
    }

    .info-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-tertiary);
      margin-bottom: 3px;
    }

    .info-value {
      font-size: 14px;
      font-weight: 600;
      font-family: var(--font-mono);
    }

    .info-value.accent { color: var(--accent-1); }
    .info-value.success { color: var(--success); }
    .info-value.danger { color: var(--danger); }

    /* ===== Frame Grid ===== */
    .frame-grid-section { display: none; }
    .frame-grid-section.visible { display: block; }

    .frame-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 3px;
      max-height: 200px;
      overflow-y: auto;
      padding: 4px;
    }

    .frame-cell {
      width: 16px; height: 16px;
      border-radius: 3px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      transition: all 0.15s ease;
      flex-shrink: 0;
    }

    .frame-cell.received {
      background: var(--success);
      border-color: var(--success);
    }

    .frame-cell.missing {
      background: rgba(248, 81, 73, 0.2);
      border-color: rgba(248, 81, 73, 0.4);
    }

    /* ===== Buttons ===== */
    .btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px 24px;
      border-radius: var(--radius-sm);
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: all 0.25s ease;
      width: 100%;
      -webkit-tap-highlight-color: transparent;
    }

    .btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      color: #fff;
      box-shadow: 0 4px 16px rgba(0, 180, 216, 0.25);
    }

    .btn-primary:active:not(:disabled) {
      transform: scale(0.98);
    }

    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      border: 1px solid var(--border);
    }

    .btn-success {
      background: linear-gradient(135deg, var(--success), #2ea043);
      color: #fff;
      box-shadow: 0 4px 16px rgba(63, 185, 80, 0.25);
    }

    .btn-danger {
      background: rgba(248, 81, 73, 0.15);
      color: var(--danger);
      border: 1px solid rgba(248, 81, 73, 0.3);
    }

    .btn-group {
      display: flex;
      gap: 10px;
    }

    .btn-group .btn { flex: 1; }

    /* ===== Missing Frames ===== */
    .missing-section { display: none; }
    .missing-section.visible { display: block; }

    .missing-list {
      background: var(--bg-tertiary);
      border-radius: var(--radius-sm);
      padding: 12px;
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--danger);
      line-height: 1.8;
      max-height: 120px;
      overflow-y: auto;
      word-break: break-all;
    }

    /* ===== Result ===== */
    .result-section { display: none; }
    .result-section.visible { display: block; }

    .result-icon {
      text-align: center;
      font-size: 48px;
      margin-bottom: 12px;
      animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @keyframes popIn {
      0% { transform: scale(0); }
      100% { transform: scale(1); }
    }

    .result-text {
      text-align: center;
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .result-text.success { color: var(--success); }
    .result-text.error { color: var(--danger); }

    /* ===== Utility ===== */
    .hidden { display: none !important; }

    .fade-in {
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ===== Reset Button ===== */
    .reset-section {
      padding-bottom: 32px;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  </style>
</head>
<body>

  <!-- ===== Header ===== -->
  <header class="header">
    <div class="header-icon">📱</div>
    <h1>光学式CSV転送<span>受信側</span></h1>
  </header>

  <!-- ===== Main Content ===== -->
  <div class="container">

    <!-- Camera -->
    <div class="card">
      <div class="card-title"><span class="icon">📷</span> カメラ</div>
      <div class="camera-container" id="camera-container">
        <video id="video" playsinline autoplay muted></video>
        <div class="camera-placeholder" id="camera-placeholder">
          <span class="icon">📷</span>
          <div>カメラを開始してください</div>
        </div>
        <div class="scan-overlay" id="scan-overlay">
          <div class="corner-bl"></div>
          <div class="corner-br"></div>
          <div class="scan-line" id="scan-line"></div>
        </div>
        <div class="detection-flash" id="detection-flash"></div>
      </div>
      <canvas id="scan-canvas" style="display:none;"></canvas>
    </div>

    <!-- Controls -->
    <div class="btn-group">
      <button class="btn btn-primary" id="btn-camera">📷 カメラ開始</button>
      <button class="btn btn-success hidden" id="btn-save" disabled>💾 CSV保存</button>
    </div>
    <button class="btn btn-danger hidden" id="btn-camera-stop">⏹ カメラ停止</button>

    <!-- Status -->
    <div class="card">
      <div class="card-title"><span class="icon">📊</span> 受信状態</div>
      <div class="status-section">
        <div class="status-row">
          <div class="status-dot" id="status-dot"></div>
          <span class="status-label" id="status-label">待機中</span>
          <span class="status-detail" id="status-detail"></span>
        </div>
        <div class="progress-bar-container">
          <div class="progress-bar-fill" id="progress-fill"></div>
        </div>
        <div class="progress-text">
          <span id="progress-received">受信: 0</span>
          <span id="progress-total">全体: —</span>
        </div>
      </div>
    </div>

    <!-- Transfer Info -->
    <div class="card transfer-info" id="transfer-info">
      <div class="card-title"><span class="icon">📋</span> 転送情報</div>
      <div class="info-grid">
        <div class="info-item">
          <div class="info-label">Transfer ID</div>
          <div class="info-value accent" id="info-tid">—</div>
        </div>
        <div class="info-item">
          <div class="info-label">ファイル名</div>
          <div class="info-value" id="info-filename">—</div>
        </div>
        <div class="info-item">
          <div class="info-label">受信済み</div>
          <div class="info-value success" id="info-received-count">0</div>
        </div>
        <div class="info-item">
          <div class="info-label">不足</div>
          <div class="info-value danger" id="info-missing-count">—</div>
        </div>
      </div>
    </div>

    <!-- Frame Grid -->
    <div class="card frame-grid-section" id="frame-grid-section">
      <div class="card-title"><span class="icon">🗂️</span> フレーム受信状況</div>
      <div class="frame-grid" id="frame-grid"></div>
    </div>

    <!-- Missing Frames -->
    <div class="card missing-section" id="missing-section">
      <div class="card-title"><span class="icon">⚠️</span> 不足フレーム一覧</div>
      <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 8px;">
        以下の番号を送信側に入力して再送してください
      </p>
      <div class="missing-list" id="missing-list"></div>
    </div>

    <!-- Result -->
    <div class="card result-section" id="result-section">
      <div class="result-icon" id="result-icon">✅</div>
      <div class="result-text" id="result-text">転送成功</div>
      <div class="info-grid" id="result-info" style="margin-bottom: 16px;"></div>
      <button class="btn btn-success" id="btn-download">💾 CSVをダウンロード</button>
    </div>

    <!-- Reset -->
    <div class="reset-section">
      <button class="btn btn-secondary" id="btn-reset">🔄 リセット</button>
    </div>
  </div>

  <script>
    // ========================================
    // Utility Functions
    // ========================================

    /** CRC32 lookup table */
    const CRC32_TABLE = (() => {
      const table = new Uint32Array(256);
      for (let i = 0; i < 256; i++) {
        let c = i;
        for (let j = 0; j < 8; j++) {
          c = (c & 1) ? (0xEDB88320 ^ (c >>> 1)) : (c >>> 1);
        }
        table[i] = c;
      }
      return table;
    })();

    function crc32(data) {
      let crc = 0xFFFFFFFF;
      for (let i = 0; i < data.length; i++) {
        crc = CRC32_TABLE[(crc ^ data[i]) & 0xFF] ^ (crc >>> 8);
      }
      return (crc ^ 0xFFFFFFFF) >>> 0;
    }

    /** Decode Base64 to Uint8Array */
    function base64ToUint8Array(base64) {
      const raw = atob(base64);
      const bytes = new Uint8Array(raw.length);
      for (let i = 0; i < raw.length; i++) {
        bytes[i] = raw.charCodeAt(i);
      }
      return bytes;
    }

    function formatBytes(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    // ========================================
    // State
    // ========================================

    let state = 'idle'; // idle | scanning | receiving | assembling | verified | error
    let transferId = null;
    let totalFrames = 0;
    let expectedCRC = 0;
    let originalFileName = 'download.csv';
    let receivedFrames = new Map(); // frameNumber → base64 data
    let fileData = null; // Uint8Array - decompressed file data
    let cameraStream = null;
    let scanActive = false;
    let lastScanTime = 0;
    let detectionTimeout = null;

    const SCAN_INTERVAL = 1000 / 20; // Max 20fps scan rate

    // ========================================
    // DOM References
    // ========================================

    const video = document.getElementById('video');
    const scanCanvas = document.getElementById('scan-canvas');
    const scanCtx = scanCanvas.getContext('2d', { willReadFrequently: true });
    const cameraPlaceholder = document.getElementById('camera-placeholder');
    const scanOverlay = document.getElementById('scan-overlay');
    const scanLine = document.getElementById('scan-line');
    const detectionFlash = document.getElementById('detection-flash');
    const btnCamera = document.getElementById('btn-camera');
    const btnCameraStop = document.getElementById('btn-camera-stop');
    const btnSave = document.getElementById('btn-save');
    const btnDownload = document.getElementById('btn-download');
    const btnReset = document.getElementById('btn-reset');
    const statusDot = document.getElementById('status-dot');
    const statusLabel = document.getElementById('status-label');
    const statusDetail = document.getElementById('status-detail');
    const progressFill = document.getElementById('progress-fill');
    const progressReceived = document.getElementById('progress-received');
    const progressTotal = document.getElementById('progress-total');
    const transferInfo = document.getElementById('transfer-info');
    const frameGridSection = document.getElementById('frame-grid-section');
    const frameGrid = document.getElementById('frame-grid');
    const missingSection = document.getElementById('missing-section');
    const missingList = document.getElementById('missing-list');
    const resultSection = document.getElementById('result-section');
    const resultIcon = document.getElementById('result-icon');
    const resultText = document.getElementById('result-text');
    const resultInfo = document.getElementById('result-info');

    // ========================================
    // Camera
    // ========================================

    async function startCamera() {
      try {
        setStatus('idle', 'カメラ起動中...', '');
        cameraStream = await navigator.mediaDevices.getUserMedia({
          video: {
            facingMode: { ideal: 'environment' },
            width: { ideal: 1280 },
            height: { ideal: 720 }
          },
          audio: false
        });

        video.srcObject = cameraStream;
        await video.play();

        cameraPlaceholder.style.display = 'none';
        scanLine.style.display = 'block';
        btnCamera.classList.add('hidden');
        btnCameraStop.classList.remove('hidden');

        scanActive = true;
        state = 'scanning';
        setStatus('active', 'スキャン中', 'QRを映してください');

        // Request wake lock
        if ('wakeLock' in navigator) {
          try { await navigator.wakeLock.request('screen'); } catch (e) {}
        }

        requestAnimationFrame(scanLoop);
      } catch (err) {
        setStatus('error', 'カメラエラー', err.message);
        alert('カメラにアクセスできません。\nHTTPS接続が必要です。\n\n' + err.message);
      }
    }

    function stopCamera() {
      scanActive = false;
      if (cameraStream) {
        cameraStream.getTracks().forEach(t => t.stop());
        cameraStream = null;
      }
      video.srcObject = null;
      cameraPlaceholder.style.display = 'flex';
      scanLine.style.display = 'none';
      btnCamera.classList.remove('hidden');
      btnCameraStop.classList.add('hidden');

      if (state === 'scanning') {
        state = 'idle';
        setStatus('idle', '待機中', '');
      }
    }

    // ========================================
    // QR Scanning
    // ========================================

    function scanLoop(timestamp) {
      if (!scanActive) return;

      if (timestamp - lastScanTime >= SCAN_INTERVAL) {
        lastScanTime = timestamp;

        if (video.readyState >= video.HAVE_ENOUGH_DATA) {
          const vw = video.videoWidth;
          const vh = video.videoHeight;

          if (vw > 0 && vh > 0) {
            scanCanvas.width = vw;
            scanCanvas.height = vh;
            scanCtx.drawImage(video, 0, 0, vw, vh);

            const imageData = scanCtx.getImageData(0, 0, vw, vh);
            const code = jsQR(imageData.data, imageData.width, imageData.height, {
              inversionAttempts: 'dontInvert'
            });

            if (code && code.data) {
              processQRData(code.data);
            }
          }
        }
      }

      requestAnimationFrame(scanLoop);
    }

    // ========================================
    // Frame Processing
    // ========================================

    function processQRData(data) {
      let frame;
      try {
        frame = JSON.parse(data);
      } catch (e) {
        return; // Not our QR code
      }

      // Validate frame structure
      if (frame.v !== 1 || !frame.id || typeof frame.t !== 'number' ||
          typeof frame.n !== 'number' || typeof frame.d !== 'string') {
        return;
      }

      // First frame - initialize transfer
      if (transferId === null) {
        transferId = frame.id;
        totalFrames = frame.t;
        state = 'receiving';
        initFrameGrid();
        transferInfo.classList.add('visible');
        transferInfo.classList.add('fade-in');
        frameGridSection.classList.add('visible');
        frameGridSection.classList.add('fade-in');
        document.getElementById('info-tid').textContent = frame.id.toUpperCase();
      }

      // Check Transfer ID
      if (frame.id !== transferId) return;

      // Check duplicate
      if (receivedFrames.has(frame.n)) return;

      // Store frame
      receivedFrames.set(frame.n, frame.d);

      // Extract metadata from frame 0
      if (frame.n === 0 && frame.c !== undefined) {
        expectedCRC = frame.c;
        originalFileName = frame.f || 'download.csv';
        document.getElementById('info-filename').textContent = originalFileName;
      }

      // Visual feedback
      flashDetection();
      updateFrameGrid(frame.n);
      updateProgress();

      // Check completion
      if (receivedFrames.size === totalFrames) {
        assembleAndVerify();
      }
    }

    // ========================================
    // Detection Feedback
    // ========================================

    function flashDetection() {
      detectionFlash.classList.add('active');
      scanOverlay.classList.add('detected');
      if (detectionTimeout) clearTimeout(detectionTimeout);
      detectionTimeout = setTimeout(() => {
        detectionFlash.classList.remove('active');
        scanOverlay.classList.remove('detected');
      }, 150);
    }

    // ========================================
    // Frame Grid
    // ========================================

    function initFrameGrid() {
      frameGrid.innerHTML = '';
      for (let i = 0; i < totalFrames; i++) {
        const cell = document.createElement('div');
        cell.className = 'frame-cell';
        cell.id = 'fc-' + i;
        cell.title = 'Frame ' + i;
        frameGrid.appendChild(cell);
      }
    }

    function updateFrameGrid(frameNum) {
      const cell = document.getElementById('fc-' + frameNum);
      if (cell) {
        cell.classList.add('received');
      }
    }

    // ========================================
    // Progress
    // ========================================

    function updateProgress() {
      const received = receivedFrames.size;
      const pct = totalFrames > 0 ? (received / totalFrames * 100) : 0;

      progressFill.style.width = pct + '%';
      progressReceived.textContent = `受信: ${received}`;
      progressTotal.textContent = `全体: ${totalFrames}`;
      document.getElementById('info-received-count').textContent = received;

      const missing = totalFrames - received;
      document.getElementById('info-missing-count').textContent = missing;

      setStatus('active', '受信中', pct.toFixed(0) + '%');

      // Update missing frames display
      if (missing > 0 && received > 0) {
        updateMissingList();
      }
    }

    function updateMissingList() {
      const missing = getMissingFrames();
      if (missing.length === 0) {
        missingSection.classList.remove('visible');
        return;
      }
      missingSection.classList.add('visible');
      missingList.textContent = missing.join(', ');

      // Mark missing cells
      for (const num of missing) {
        const cell = document.getElementById('fc-' + num);
        if (cell && !cell.classList.contains('received')) {
          cell.classList.add('missing');
        }
      }
    }

    function getMissingFrames() {
      const missing = [];
      for (let i = 0; i < totalFrames; i++) {
        if (!receivedFrames.has(i)) {
          missing.push(i);
        }
      }
      return missing;
    }

    // ========================================
    // Assembly & Verification
    // ========================================

    function assembleAndVerify() {
      state = 'assembling';
      setStatus('complete', 'CRC確認中...', '');
      stopCamera();

      // Small delay for UI update
      setTimeout(() => {
        try {
          // Concatenate base64 chunks in order
          let fullBase64 = '';
          for (let i = 0; i < totalFrames; i++) {
            fullBase64 += receivedFrames.get(i);
          }

          // Decode base64
          const compressedData = base64ToUint8Array(fullBase64);

          // Verify CRC
          const actualCRC = crc32(compressedData);
          if (actualCRC !== expectedCRC) {
            showError(`CRC不一致\n期待値: ${expectedCRC.toString(16).toUpperCase()}\n実際値: ${actualCRC.toString(16).toUpperCase()}`);
            return;
          }

          // Decompress
          fileData = pako.ungzip(compressedData);

          // Success
          state = 'verified';
          progressFill.classList.add('complete');
          progressFill.style.width = '100%';
          showSuccess(compressedData.length, fileData.length);

        } catch (e) {
          showError('データ復元エラー: ' + e.message);
        }
      }, 300);
    }

    // ========================================
    // Results
    // ========================================

    function showSuccess(compressedSize, originalSize) {
      setStatus('verified', '保存完了', '✓');

      resultSection.classList.add('visible');
      resultSection.classList.add('fade-in');
      resultIcon.textContent = '✅';
      resultText.textContent = '転送成功 — CRC一致';
      resultText.className = 'result-text success';

      resultInfo.innerHTML = `
        <div class="info-item">
          <div class="info-label">ファイル名</div>
          <div class="info-value">${originalFileName}</div>
        </div>
        <div class="info-item">
          <div class="info-label">ファイルサイズ</div>
          <div class="info-value accent">${formatBytes(originalSize)}</div>
        </div>
        <div class="info-item">
          <div class="info-label">Transfer ID</div>
          <div class="info-value accent">${transferId.toUpperCase()}</div>
        </div>
        <div class="info-item">
          <div class="info-label">フレーム数</div>
          <div class="info-value success">${totalFrames}</div>
        </div>
      `;

      btnSave.classList.remove('hidden');
      btnSave.disabled = false;
      missingSection.classList.remove('visible');
    }

    function showError(message) {
      state = 'error';
      setStatus('error', 'エラー', '✕');

      resultSection.classList.add('visible');
      resultSection.classList.add('fade-in');
      resultIcon.textContent = '❌';
      resultText.textContent = message;
      resultText.className = 'result-text error';
      resultInfo.innerHTML = '';

      // Show missing frames for re-request
      updateMissingList();
    }

    // ========================================
    // File Download
    // ========================================

    function downloadFile() {
      if (!fileData) return;

      const blob = new Blob([fileData], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);

      const a = document.createElement('a');
      a.href = url;
      a.download = originalFileName;
      document.body.appendChild(a);
      a.click();

      setTimeout(() => {
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      }, 100);
    }

    // ========================================
    // Status Updates
    // ========================================

    function setStatus(type, label, detail) {
      statusDot.className = 'status-dot ' + type;
      statusLabel.textContent = label;
      if (detail !== undefined) statusDetail.textContent = detail;
    }

    // ========================================
    // Reset
    // ========================================

    function resetAll() {
      stopCamera();

      state = 'idle';
      transferId = null;
      totalFrames = 0;
      expectedCRC = 0;
      originalFileName = 'download.csv';
      receivedFrames = new Map();
      fileData = null;

      // Reset UI
      setStatus('idle', '待機中', '');
      progressFill.style.width = '0%';
      progressFill.classList.remove('complete');
      progressReceived.textContent = '受信: 0';
      progressTotal.textContent = '全体: —';
      transferInfo.classList.remove('visible');
      frameGridSection.classList.remove('visible');
      frameGrid.innerHTML = '';
      missingSection.classList.remove('visible');
      resultSection.classList.remove('visible');
      btnSave.classList.add('hidden');
      btnSave.disabled = true;
    }

    // ========================================
    // Event Listeners
    // ========================================

    btnCamera.addEventListener('click', startCamera);
    btnCameraStop.addEventListener('click', () => {
      stopCamera();
      if (totalFrames > 0 && receivedFrames.size < totalFrames) {
        updateMissingList();
      }
    });
    btnSave.addEventListener('click', downloadFile);
    btnDownload.addEventListener('click', downloadFile);
    btnReset.addEventListener('click', () => {
      if (receivedFrames.size > 0 && state !== 'verified') {
        if (!confirm('受信データがリセットされます。よろしいですか？')) return;
      }
      resetAll();
    });

  </script>
</body>
</html>
